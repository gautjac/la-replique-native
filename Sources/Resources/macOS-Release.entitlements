<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox: required for a distributable native macOS app. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Import .json/.txt plays and write exported files to user-chosen paths. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!-- Network: BYOK Claude (Anthropic) + ElevenLabs TTS + CloudKit sync. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- iCloud / CloudKit private-DB sync of plays across the user's devices.
	     RELEASE build → production APS so CloudKit push (and thus SwiftData
	     cross-device sync) works on TestFlight / App Store. Debug uses the
	     development variant. -->
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.app.atelier.lareplique</string>
	</array>
	<!-- NOTE: macOS uses com.apple.developer.aps-environment; the bare
	     `aps-environment` key is iOS-only and is silently STRIPPED at signing on
	     macOS — which is exactly what broke CloudKit push (and cross-device sync)
	     on the Mac through builds 38–41. -->
	<key>com.apple.developer.aps-environment</key>
	<string>production</string>
</dict>
</plist>
